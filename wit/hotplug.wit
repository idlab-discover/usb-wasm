// Hotplug notification interface for WASI-USB.
// This interface allows components to be notified when USB devices 
// are connected or disconnected from the system.

interface usb-hotplug {
    use errors.{libusb-error};
    use device.{usb-device};

    flags event { arrived, left }

    record info {
        bus: u8,
        address: u8,
        vendor: u16,
        product: u16,
    }

    enable-hotplug: func() -> result<_, libusb-error>;
    poll-events: func() -> list<tuple<event, info, usb-device>>;
}
