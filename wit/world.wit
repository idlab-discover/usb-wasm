package component:usb@0.2.1;

/// Host world — implemented by the wasmtime-usb / usb-wasi-host binary.
/// The host provides all USB primitives; no UVC, MJPEG, or ML lives here.
world host {
    import transfers;
    import errors;
    import device;
    import descriptors;
    import configuration;
    import usb-hotplug;
}

/// C-guest world — used by libusb-wasi C benchmark components.
/// Exports wasi:cli/run so the component can be invoked as a command.
world cguest {
    import transfers;
    import errors;
    import device;
    import descriptors;
    import configuration;
    import usb-hotplug;

    export wasi:cli/run@0.2.5;
}

/// Webcam guest world — used by the webcam Rust component.
/// A standalone command that captures UVC frames and prints statistics.
world webcam-guest {
    import transfers;
    import errors;
    import device;
    import descriptors;
    import configuration;
    import usb-hotplug;

    import wasi:cli/environment@0.2.5;
    import wasi:cli/exit@0.2.5;
    import wasi:cli/stderr@0.2.5;
    import wasi:cli/stdin@0.2.5;
    import wasi:cli/stdout@0.2.5;
    import wasi:filesystem/types@0.2.5;
    import wasi:filesystem/preopens@0.2.5;

    export wasi:cli/run@0.2.5;
}
