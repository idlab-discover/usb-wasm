package component:wasm-usb-app;

/// Generic raw frame stream — no USB semantics.
interface raw-frame-stream {
    record raw-frame {
        data:   list<u8>,
        width:  u32,
        height: u32,
    }

    resource frame-source {
        constructor(index: u32);
        next-frame: func() -> result<raw-frame, string>;
    }
}

world host {
    import component:usb/transfers;
    import component:usb/errors;
    import component:usb/device;
    import component:usb/descriptors;
    import component:usb/configuration;
    import component:usb/usb-hotplug;
}

world composed-app {
    import component:usb/transfers;
    import component:usb/errors;
    import component:usb/device;
    import component:usb/descriptors;
    import component:usb/configuration;
    import component:usb/usb-hotplug;

    import wasi:cli/environment@0.2.5;
    import wasi:cli/exit@0.2.5;
    import wasi:cli/stderr@0.2.5;
    import wasi:cli/stdin@0.2.5;
    import wasi:cli/stdout@0.2.5;
    import wasi:filesystem/types@0.2.5;
    import wasi:filesystem/preopens@0.2.5;

    export wasi:cli/run@0.2.5;
}

world webcam-provider-world {
    import component:usb/transfers;
    import component:usb/errors;
    import component:usb/device;
    import component:usb/descriptors;
    import component:usb/configuration;
    import component:usb/usb-hotplug;

    import wasi:io/streams@0.2.5;
    import wasi:cli/environment@0.2.5;

    export raw-frame-stream;
}

world webcam-export-only {
    export raw-frame-stream;
}

world yolo-command-world {
    import raw-frame-stream;

    import wasi:cli/environment@0.2.5;
    import wasi:cli/exit@0.2.5;
    import wasi:cli/stderr@0.2.5;
    import wasi:cli/stdin@0.2.5;
    import wasi:cli/stdout@0.2.5;
    import wasi:filesystem/types@0.2.5;
    import wasi:filesystem/preopens@0.2.5;

    export wasi:cli/run@0.2.5;
}
